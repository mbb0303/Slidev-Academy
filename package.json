{
  "name": "slidev-theme-mbb-academy",
  "version": "0.1.0",
  "description": "A restrained academic Slidev theme for scientific meeting slides.",
  "type": "module",
  "license": "MIT",
  "author": "Slidev Academy Theme Maintainers",
  "repository": {
    "type": "git",
    "url": "https://github.com/mbb0303/Slidev-Academy.git"
  },
  "keywords": [
    "slidev-theme",
    "slidev",
    "academic",
    "presentation",
    "physics",
    "meeting"
  ],
  "engines": {
    "node": ">=20.0.0",
    "slidev": ">=0.52.0"
  },
  "scripts": {
    "dev": "/opt/homebrew/bin/node node_modules/.pnpm/@slidev+cli@*/node_modules/@slidev/cli/bin/slidev.mjs slides.md --host 127.0.0.1",
    "export": "/opt/homebrew/bin/node node_modules/.pnpm/@slidev+cli@*/node_modules/@slidev/cli/bin/slidev.mjs export slides.md --output slidev-academy-demo.pdf --timeout 180000 --wait 2000 --wait-until load --per-slide --executable-path \"/Applications/Google Chrome.app/Contents/MacOS/Google Chrome\""
  },
  "slidev": {
    "colorSchema": "light",
    "defaults": {
      "aspectRatio": "16/9",
      "transition": "none",
      "mdc": true,
      "fonts": {
        "serif": "Times New Roman, Times",
        "sans": "Times New Roman, Times",
        "mono": "Fira Code, Menlo, monospace",
        "local": "Times New Roman"
      }
    }
  },
  "dependencies": {
    "@slidev/types": "^52.0.0",
    "katex": "^0.16.11"
  },
  "devDependencies": {
    "@slidev/cli": "^52.16.0",
    "@slidev/theme-default": "^0.25.0",
    "playwright-chromium": "^1.61.0"
  },
  "overrides": {
    "regex": "6.0.1"
  }
}
